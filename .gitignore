# macOS
.DS_Store
.AppleDouble
.LSOverride

# 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.bak
*.log
/tmp/

# 凭据
*.pem
*.key
.env
.env.local

# Node / Python(子技能如有)
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# 工作区数据(本地缓存)
.hl/workspace/
.hl/cache/

# OMC 运行时状态(不应入库)
.omc/

# hlpm-product 流程标记文件(空文件)
# .dev-completed 可入库(标志版本已交付,演示包 docs/v1/.dev-completed 即此例)
# .dev-rejected / .product-archived 是拒收/归档状态,新建时不应入库
docs/*/.dev-rejected
docs/*/.product-archived
.gstack/
